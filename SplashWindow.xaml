<Window x:Class="SobaKing.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SplashWindow"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Beige">

    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Image Source="pack://application:,,,/Images/logo 1.png"
                   Width="800"
                   Height="449"
                   Cursor="Hand"
                   MouseLeftButtonDown="Logo_Click"/>

            <TextBlock Text="Click Logo To Start"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="DarkBlue"
                       HorizontalAlignment="Center" Height="43"/>
        </StackPanel>

    </Grid>
</Window>