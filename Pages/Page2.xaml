<UserControl x:Class="SobaKing.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Grid Background="White">


        <Grid.RowDefinitions>

            <RowDefinition Height="50"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>




        <!-- Header -->
        <Border Background="#2C3E50"
                Grid.Row="0">

            <TextBlock Text="Add Menu Item"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0"/>

        </Border>





        <Grid Grid.Row="1">


            <Border Width="450"
                    Padding="20"
                    Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">



                <StackPanel>



                    <TextBlock Text="Add New Menu"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>




                    <!-- Name -->

                    <TextBlock Text="Name"
                               FontWeight="Bold"/>


                    <TextBox x:Name="txtName"
                             Height="35"
                             Margin="0,5,0,15"/>




                    <!-- Price -->

                    <TextBlock Text="Price"
                               FontWeight="Bold"/>


                    <TextBox x:Name="txtPrice"
                             Height="35"
                             Margin="0,5,0,15"/>





                    <!-- Category -->

                    <TextBlock Text="Category"
                               FontWeight="Bold"/>



                    <ComboBox x:Name="cmbCategory"
                              Height="35"
                              Margin="0,5,0,15">


                        <ComboBoxItem Content="Food"/>

                        <ComboBoxItem Content="Alcohol"/>

                        <ComboBoxItem Content="Soft Drink"/>


                    </ComboBox>





                    <!-- Image -->

                    <TextBlock Text="Image"
                               FontWeight="Bold"/>



                    <DockPanel Margin="0,5,0,15">


                        <TextBox x:Name="txtImage"
                                 Height="35"
                                 Width="300"
                                 IsReadOnly="True"/>



                        <Button Content="Browse"
                                Width="90"
                                Margin="10,0,0,0"
                                Click="BrowseImage_Click"/>


                    </DockPanel>





                    <!-- Add Button -->

                    <Button Content="Add Item"
                            Height="40"
                            Background="#2C3E50"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="AddMenuItem_Click"/>



                </StackPanel>


            </Border>


        </Grid>


    </Grid>


</UserControl>