<Page x:Class="SobaKing.Pages.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Menu">
    <Grid Background="#EEF2F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!-- Menu Title + Search -->
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🍔 Menu"
                               FontSize="28"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />

                    <!-- Search Box -->
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox"
                                 Height="35"
                                 FontSize="16"
                                 Padding="35,0,10,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 GotFocus="SearchBox_GotFocus"
                                 LostFocus="SearchBox_LostFocus"
                                 ToolTip="Search Menu..." Margin="10,1,0,1" />

                        <!-- Placeholder -->
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="🔍 Search..."
                                   Foreground="Gray"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Height="17"/>
                    </Grid>
                </Grid>

                <!-- Menu Items -->
                <ItemsControl x:Name="ItemsControlMenu">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    Width="170"
                                    Margin="10"
                                    Padding="10"
                                    CornerRadius="10">
                                <StackPanel>
                                    <Image Source="{Binding ImageUrl}"
                                           Height="120"
                                           Stretch="UniformToFill"
                                           Cursor="Hand"
                                           MouseDown="Image_Click" />
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding Price,StringFormat=¥ {0}}"
                                               TextAlignment="Center"
                                               Foreground="Gray" />
                                   
                                <!--   <Button Content="🗑 Delete"
                                            Margin="0,10,0,0"
                                            Background="#E53935"
                                            Foreground="White"
                                            Click="Delete_Click" />-->
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT CART -->
        <StackPanel Grid.Column="1" Background="White">
            <TextBlock Text="🛒 Cart"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="10" />

            <ListBox x:Name="CartListBox"
                     Margin="10"
                     Height="350">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDDDDD"
                                BorderThickness="0,0,0,1"
                                Padding="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="120" />
                                <TextBlock Text="{Binding Price}" Width="60" />
                                <Button Content="-" Width="30" Margin="5,0" Click="Minus_Click" />
                                <TextBlock Text="{Binding Quantity}" Width="30" TextAlignment="Center" />
                                <Button Content="+" Width="30" Margin="5,0" Click="Plus_Click" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock x:Name="TotalText"
                       Margin="10"
                       FontSize="20"
                       FontWeight="Bold"
                       Text="Total : ¥ 0" />

            <Button Content="Payment"
                    Margin="10"
                    Height="40"
                    Background="MediumBlue"
                    Foreground="White"
                    Click="Payment_Click" />
        </StackPanel>
    </Grid>
</Page>