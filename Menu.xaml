<Window x:Class="SobaKing.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SobaKing"
        mc:Ignorable="d"
        Title="Menu" Height="500" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Menu Buttons -->
        <StackPanel Grid.Column="0" Margin="10" VerticalAlignment="Top">
            <TextBlock Text="Soba Menu" FontSize="26" FontWeight="Bold" Margin="0 0 0 20"/>

            <Button Content="Kake Soba - ¥500" Tag="500" Click="Menu_Click" Margin="0 5" Height="50"/>
            <Button Content="Kitsune Soba - ¥650" Tag="650" Click="Menu_Click" Margin="0 5" Height="50"/>
            <Button Content="Tempura Soba - ¥800" Tag="800" Click="Menu_Click" Margin="0 5" Height="50"/>
            <Button Content="Tororo Soba - ¥700" Tag="700" Click="Menu_Click" Margin="0 5" Height="50"/>
        </StackPanel>

        <!-- Right: Order List -->
        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Order List" FontSize="26" FontWeight="Bold" Margin="0 0 0 20"/>

            <ListBox x:Name="OrderList" Height="250" FontSize="18"/>

            <StackPanel Orientation="Horizontal" Margin="0 20 0 0">
                <TextBlock Text="Total: " FontSize="22"/>
                <TextBlock x:Name="TotalText" Text="¥0" FontSize="22" FontWeight="Bold"/>
            </StackPanel>

            <Button Content="Pay" Height="50" Background="#FFCC8800" Foreground="White"
                    FontSize="20" Click="Pay_Click"/>
        </StackPanel>
    </Grid>
</Window>
