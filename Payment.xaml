<UserControl x:Class="SobaKing.Payment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SobaKing"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
        <Grid Background="#EEF2F7">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT ================= -->
            <StackPanel Grid.Column="0" Margin="15">

                <TextBlock Text="Payment"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

                <Border Background="#4CAF50" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Total" Foreground="White"/>
                        <TextBlock x:Name="TotalText"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="¥0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Paid Amount"/>
                        <TextBox x:Name="PaidTextBox"
                             FontSize="18"
                             Height="40"
                             TextChanged="PaidTextBox_TextChanged"/>
                    </StackPanel>
                </Border>

                <Border Background="#FF9800" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Change" Foreground="White"/>
                        <TextBlock x:Name="ChangeText"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="¥0"/>
                    </StackPanel>
                </Border>

                <!-- ✅ RECEIPT AREA (PRINT TARGET) -->

            </StackPanel>

            <!-- ================= CENTER KEYPAD ================= -->
            <UniformGrid Grid.Column="1" Rows="5" Columns="3" Margin="10">

                <Button Content="7" Click="Key_Click" FontSize="20"/>
                <Button Content="8" Click="Key_Click" FontSize="20"/>
                <Button Content="9" Click="Key_Click" FontSize="20"/>

                <Button Content="4" Click="Key_Click" FontSize="20"/>
                <Button Content="5" Click="Key_Click" FontSize="20"/>
                <Button Content="6" Click="Key_Click" FontSize="20"/>

                <Button Content="1" Click="Key_Click" FontSize="20"/>
                <Button Content="2" Click="Key_Click" FontSize="20"/>
                <Button Content="3" Click="Key_Click" FontSize="20"/>

                <Button Content="0" Click="Key_Click" FontSize="20"/>
                <Button Content="00" Click="Key_Click" FontSize="20"/>

                <Button Content="C" Background="Red" Foreground="White"
                    Click="Clear_Click" FontSize="20"/>

                <Button Content="Exact" Background="Blue" Foreground="White"
                    Click="Exact_Click" FontSize="20"/>
            </UniformGrid>

            <!-- ================= RIGHT ================= -->
            <StackPanel Grid.Column="2" Margin="15">

                <TextBlock Text="Payment Method"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

                <Button x:Name="Cash" Content="Cash" Background="White" Click="Cash_Click" Margin="5" Height="52" FontSize="16" FontWeight="Bold"/>
                <Button Content="Credit Card" Background="White" Click="CreditCard_Click" Margin="5" Height="52" FontSize="16" FontWeight="Bold"/>
                <Button Content="E-Money" Background="White" Click="Emoney_Click" Margin="5" Height="52" FontSize="16" FontWeight="Bold"/>
                <Button Content="QR Code" Background="White" Click="Qrcode_Click" Margin="5" Height="52" FontSize="16" FontWeight="Bold"/>



            </StackPanel>

        </Grid>
    </UserControl>
